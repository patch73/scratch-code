package mypackage;
import javax.swing.*;
public class romano_hotelreservationGUI {
	public static void main(String[] args) {
		
		int numfloors = 7;
		int numrooms = 5;
		
		int hotel [][] = new int[numfloors][numrooms];
		
		int choice = 0;
		
		do {
			choice = Integer.parseInt(JOptionPane.showInputDialog(null,  "=== HOTEL RESERVATION SYSTEM === \n[1] View Rooms \n"
				+ "[2] Check In \n[3] Check Out \n[4] Exit ","Enter choice: ", JOptionPane.QUESTION_MESSAGE));
		
			
			
			switch (choice) {
			
			case 1:
				
				String table = "";
				
				for (int a = hotel.length - 1; a >= 0; a--) {
					table += "Floor " + (a+1)  + ": ";
					for (int b = 0; b < hotel[a].length; b++) {
						table += "[" + hotel[a][b] + "]" ;
					}
		
					table += "\n";
				}
				JOptionPane.showMessageDialog(null,  table, "Hotel Occupancy Map", JOptionPane.INFORMATION_MESSAGE);
				break;
			
			case 2:
				
				int choicefloor = Integer.parseInt (JOptionPane.showInputDialog(null, "Enter floor (1-7): " ));
				
				int choiceroom = Integer.parseInt (JOptionPane.showInputDialog(null, "Enter room (1-7): " ));

				
				int row = choicefloor - 1;
				int column = choiceroom - 1;
				
				if (hotel[row][column] == 0) {
					hotel [row] [column] = 1;
					
					 int checkIn = JOptionPane.showConfirmDialog(null, 
					            "The room is ready. Would you like to check in now?", 
					            "Hotel Front Desk", 
					            JOptionPane.YES_NO_OPTION);
					
					JOptionPane.showMessageDialog(null, ""
							+ "Check in Succesful");
				} else {
					JOptionPane.showMessageDialog(null,"Room already occupied!", "", JOptionPane.WARNING_MESSAGE );
				}
				
				break;		 
			
				
			case 3: 
				
				int checkoutfloor = Integer.parseInt (JOptionPane.showInputDialog(null, "Enter floor (1-7): " ));
				
				int checkoutroom = Integer.parseInt (JOptionPane.showInputDialog(null, "Enter room (1-7): " ));

				
				
				int checkoutRow = checkoutfloor - 1;
				int checkoutColumn = checkoutroom - 1; 
				
				if (hotel[checkoutRow][checkoutColumn] == 1) {
					hotel [checkoutRow] [checkoutColumn] = 0;
					
					 int checkIn = JOptionPane.showConfirmDialog(null, "Are you sure you want to check out and settle your bill?", 
					            "Check-Out", 
					            JOptionPane.OK_CANCEL_OPTION);
					
					 JOptionPane.showMessageDialog(null,"Checkout Succesfully!" );
				} else {
					JOptionPane.showMessageDialog(null,"Room already empty!", "", JOptionPane.WARNING_MESSAGE );
				}
		
				break;
				
			case 4: 
				JOptionPane.showMessageDialog(null, "Exiting Pragram...");
				break;
				
				default:
				JOptionPane.showMessageDialog(null,"Invalid Choice" );

			}
				
			
		} while (choice != 4);		
		
	}
}
